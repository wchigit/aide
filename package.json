{
  "name": "aide",
  "version": "0.2.8",
  "description": "A personal work agent that sees the full picture, learns as you work, and helps you get things done.",
  "author": {
    "name": "Aide",
    "email": "aide@users.noreply.github.com"
  },
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "typecheck": "tsc --noEmit",
    "preview": "electron-vite preview",
    "icons": "node scripts/generate-icons.js",
    "social": "node scripts/generate-social-preview.js",
    "dist": "electron-vite build && electron-builder",
    "dist:mac": "electron-vite build && electron-builder --mac",
    "dist:win": "electron-vite build && electron-builder --win",
    "dist:linux": "electron-vite build && electron-builder --linux",
    "postinstall": "electron-builder install-app-deps",
    "download:browser": "npx playwright install chromium"
  },
  "dependencies": {
    "@nut-tree-fork/nut-js": "^4.2.0",
    "@github/copilot-sdk": "^1.0.0",
